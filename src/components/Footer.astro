---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const LINKEDIN_URL = 'https://www.linkedin.com/company/soloex-io/';
const UPWORK_URL = 'https://www.upwork.com/freelancers/~01a68484f6725225f8';
const APPEXCHANGE_URL = 'https://appexchange.salesforce.com/appxConsultingListingDetail?listingId=e53f67f8-98b6-4bb3-b7ff-b6e204de0b14&legacy=true';
---

<footer class="footer">
  <div class="container-wide footer-main">
    <div class="footer-brand">
      <Logo />
      <p class="footer-tagline">Salesforce and HubSpot consultancy. Women-owned, WBENC certified.</p>
    </div>

    <div class="footer-col">
      <h2 class="footer-heading">Services</h2>
      <ul class="footer-links">
        <li><a href="/services#implement">Implement</a></li>
        <li><a href="/services#migrate">Migrate</a></li>
        <li><a href="/services#optimize">Optimize</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-heading">Company</h2>
      <ul class="footer-links">
        <li><a href="/about">About</a></li>
        <li><a href="/process">Process</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-heading">Get in touch</h2>
      <ul class="footer-contact">
        <li><a href="mailto:derek.beitz@soloex.io">derek.beitz@soloex.io</a></li>
        <li><a href="tel:+17176096032">(717) 609-6032</a></li>
        <li>Mechanicsburg, PA</li>
      </ul>
      <div class="footer-social" aria-label="Soloex on the web">
        <a href={LINKEDIN_URL} target="_blank" rel="noopener" class="social-icon" aria-label="Soloex on LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.25 8h4.5v14H.25V8zM8 8h4.3v1.9h.06c.6-1.1 2.07-2.3 4.26-2.3C21.15 7.6 22 10.2 22 13.5V22h-4.5v-7.5c0-1.8-.03-4.1-2.5-4.1s-2.9 1.95-2.9 3.97V22H8V8z"/>
          </svg>
        </a>
        <a href={UPWORK_URL} target="_blank" rel="noopener" class="social-icon" aria-label="Soloex on Upwork">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.56 13.4c-1.17 0-2.27-.5-3.28-1.3l.25-1.14c.22-1.24.9-3.33 3.03-3.33 1.6 0 2.9 1.3 2.9 2.9s-1.3 2.87-2.9 2.87zm0-8.66c-2.72 0-4.83 1.76-5.69 4.66-1.3-1.97-2.3-4.34-2.88-6.31H7.12v7.66c0 1.5-1.23 2.74-2.74 2.74-1.5 0-2.74-1.23-2.74-2.74V3.09H-1.1v7.66c0 3.1 2.53 5.64 5.64 5.64 3.1 0 5.64-2.53 5.64-5.64V10.04c.56 1.1 1.24 2.2 2.04 3.2l-1.73 8.14h2.9l1.26-5.92c1.1.7 2.37 1.1 3.75 1.1 3.07 0 5.58-2.54 5.58-5.6 0-3.07-2.48-5.58-5.58-5.58z" transform="translate(1.1)"/>
          </svg>
        </a>
        <a href={APPEXCHANGE_URL} target="_blank" rel="noopener" class="social-icon" aria-label="Soloex on Salesforce AppExchange">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9.88 4.2a4.5 4.5 0 0 1 7.28 1.19 3.7 3.7 0 0 1 4.63 1.84 3.8 3.8 0 0 1-.93 4.63 3.6 3.6 0 0 1 .52 4.8 3.7 3.7 0 0 1-4.8 1.08 4.5 4.5 0 0 1-7.65 0 3.7 3.7 0 0 1-4.8-1.08 3.6 3.6 0 0 1 .52-4.8A3.8 3.8 0 0 1 3.7 7.23 3.7 3.7 0 0 1 8.34 5.4 4.5 4.5 0 0 1 9.88 4.2zm-.5 7.5c1.25-.08 1.7.9 2.74.9.6 0 1.05-.3 1.05-.7 0-.35-.2-.52-.85-.66l-.65-.13c-1.28-.27-2.05-.94-2.05-1.98 0-1.24 1.05-2.15 2.52-2.15 1.05 0 1.98.5 2.55 1.25l-.93.7c-.45-.52-.93-.73-1.55-.73-.63 0-1.05.26-1.05.66 0 .3.25.5.85.62l.7.15c1.35.28 2.05.9 2.05 2 0 1.3-1.12 2.2-2.65 2.2-1.12 0-2.15-.5-2.73-1.33l.98-.8z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="container-wide footer-bar">
    <div class="footer-legal">
      <span>© {year} Soloex.io · All rights reserved</span>
      <span class="separator">·</span>
      <a href="/privacy">Privacy</a>
      <span class="separator">·</span>
      <a href="/terms">Terms</a>
    </div>
    <div class="footer-badges">
      <!-- Swap these text pills for real WBENC + Salesforce Partner badge SVGs when available. -->
      <span class="pill">WBENC certified</span>
      <span class="pill">Salesforce Partner</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #FFFFFF;
    border-top: 0.5px solid var(--color-border-soft);
    padding: 64px 0 24px;
    margin-top: 0;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
    gap: 32px;
    padding-bottom: 40px;
  }

  .footer-brand { max-width: 300px; }

  .footer-tagline {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-top: 14px;
  }

  .footer-heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    margin: 0 0 16px;
  }

  .footer-links,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a,
  .footer-contact a,
  .footer-contact li {
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .footer-links a:hover,
  .footer-contact a:hover { color: var(--color-ink-700); }

  .footer-social {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }

  .social-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-tinted);
    border: 1px solid var(--color-border);
    color: var(--color-ink-700);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .social-icon:hover {
    background: var(--color-ink-700);
    border-color: var(--color-ink-700);
    color: #fff;
  }

  .footer-bar {
    padding-top: 22px;
    border-top: 0.5px solid var(--color-border-soft);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--color-text-tertiary);
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-legal span,
  .footer-legal a {
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .separator {
    margin: 0 8px;
    color: var(--color-text-tertiary);
  }

  .footer-badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  @media (max-width: 820px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-brand {
      grid-column: span 2;
      max-width: none;
    }
    .footer-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .footer-main { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
  }
</style>
