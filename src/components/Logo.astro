---
import { Image } from 'astro:assets';
import logoImg from '../assets/soloex-logo-for-light-bg.png';

interface Props {
  height?: number;
  class?: string;
}

const { height = 40, class: className = '' } = Astro.props;
const width = Math.round((height * logoImg.width) / logoImg.height);
---

<Image
  src={logoImg}
  alt="Soloex.io"
  width={width}
  height={height}
  densities={[1, 2]}
  loading="eager"
  decoding="async"
  class={`logo-img ${className}`}
/>

<style>
  .logo-img {
    display: block;
    height: auto;
    max-width: 100%;
  }
</style>
