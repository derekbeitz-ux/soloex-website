---
interface Props {
  size?: number;
  showWordmark?: boolean;
  class?: string;
}

const { size = 26, showWordmark = true, class: className = '' } = Astro.props;
---

<span class={`logo ${className}`}>
  <svg width={size} height={size} viewBox="0 0 26 26" fill="none" aria-hidden="true">
    <path d="M13 2 L24 13 L13 24 L2 13 Z" stroke="var(--color-ink-700)" stroke-width="1.3" fill="none" stroke-linejoin="round" />
    <path d="M6 8 Q13 7 20 9"   stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" />
    <path d="M5 10 Q13 9 21 11" stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" />
    <path d="M4 12 Q13 11 22 13" stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" />
    <path d="M4 14 Q13 15 22 13" stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.85" />
    <path d="M5 16 Q13 17 21 15" stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.85" />
    <path d="M6 18 Q13 19 20 17" stroke="var(--color-ink-500)" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.85" />
  </svg>
  {showWordmark && <span class="wordmark">Soloex.io</span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-ink-900);
  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--color-ink-900);
  }
</style>
